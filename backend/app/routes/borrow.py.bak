from fastapi import APIRouter, Depends, HTTPException, status
from sqlalchemy.orm import Session
from typing import List
import logging
from datetime import datetime, timedelta
from uuid import UUID

from ..core.database import get_db
from ..crud import crud_book, crud_borrow, crud_user
from ..schemas.borrow_record import BorrowRecord, BorrowRecordCreate
from ..schemas.token import TokenPayload
from ..routes.auth import get_current_user

# Set up logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

router = APIRouter(prefix="/borrow", tags=["borrow"])

@router.post("/", response_model=BorrowRecord)
async def create_borrow_record(
    record: BorrowRecordCreate,
    db: Session = Depends(get_db),
    current_user: TokenPayload = Depends(get_current_user)
):
    try:
        logger.info(f"Creating borrow record. User: {current_user.user_id}")
        logger.info(f"Received borrow data: {record.dict()}")
        
        # Verify book exists and has available copies
        book = crud_book.get_book(db, record.book_id)
        if not book:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Book not found"
            )
        
        if book.available_copies <= 0:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="No copies available for borrowing"
            )
        
        # Verify user exists
        user = crud_user.get_user(db, record.user_id)
        if not user:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="User not found"
            )
        
        # Check if user already has this book borrowed
        existing_borrows = crud_borrow.get_user_borrow_records(db, str(record.user_id))
        for borrow in existing_borrows:
            if (str(borrow.book_id) == str(record.book_id) and 
                borrow.status in ["borrowed", "overdue"]):
                raise HTTPException(
                    status_code=status.HTTP_400_BAD_REQUEST,
                    detail="User already has this book borrowed"
                )
        
        # Create borrow record
        db_record = crud_borrow.create_borrow_record(db, record)
        
        # Update book's available copies
        book.available_copies -= 1
        if book.available_copies == 0:
            book.status = "reserved"
        db.commit()
        
        return db_record
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error creating borrow record: {str(e)}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Error creating borrow record: {str(e)}"
        )

@router.put("/return/{record_id}")
async def return_borrowed_book(
    record_id: str,
    db: Session = Depends(get_db),
    current_user: TokenPayload = Depends(get_current_user)
):
    try:
        logger.info(f"Processing book return. Record ID: {record_id}")
        
        # Get borrow record
        borrow_record = crud_borrow.get_borrow_record(db, record_id)
        if not borrow_record:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Borrow record not found"
            )
        
        # Verify book exists
        book = crud_book.get_book(db, borrow_record.book_id)
        if not book:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Book not found"
            )
        
        # Update borrow record
        updated_record = crud_borrow.return_book(db, record_id)
        if not updated_record:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail="Could not process return"
            )
        
        # Update book's available copies
        book.available_copies += 1
        if book.available_copies > 0:
            book.status = "available"
        db.commit()
        
        return {"message": "Book returned successfully"}
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error processing book return: {str(e)}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Error processing book return: {str(e)}"
        )

@router.get("/user/{user_id}", response_model=List[BorrowRecord])
async def get_user_borrows(
    user_id: str,
    db: Session = Depends(get_db),
    current_user: TokenPayload = Depends(get_current_user)
):
    if not current_user.is_admin and str(current_user.user_id) != user_id:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Not authorized to view other user's borrow records"
        )
    
    return crud_borrow.get_user_borrow_records(db, user_id)

@router.get("/book/{book_id}", response_model=List[BorrowRecord])
async def get_book_borrows(
    book_id: str,
    db: Session = Depends(get_db),
    current_user: TokenPayload = Depends(get_current_user)
):
    if not current_user.is_admin:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Not authorized to view book borrow records"
        )
    
    return crud_borrow.get_book_borrow_records(db, book_id)

@router.get("/active", response_model=List[BorrowRecord])
async def get_active_borrows(
    db: Session = Depends(get_db),
    current_user: TokenPayload = Depends(get_current_user)
):
    if not current_user.is_admin:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Not authorized to view active borrows"
        )
    
    return crud_borrow.get_active_borrows(db)

@router.post("/issue/{book_id}", response_model=BorrowRecord)
async def issue_book(
    book_id: str,
    user_id: str,
    days: int = 14,
    db: Session = Depends(get_db),
    current_user: TokenPayload = Depends(get_current_user)
):
    """Issue a book to a user"""
    try:
        if not current_user.is_admin:
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail="Only administrators can issue books"
            )

        # Create borrow record data
        borrow_data = BorrowRecordCreate(
            book_id=book_id,
            user_id=user_id,
            borrow_date=datetime.utcnow(),
            due_date=datetime.utcnow() + timedelta(days=days),
            status="borrowed"
        )

        # Create the borrow record using existing endpoint logic
        return await create_borrow_record(borrow_data, db, current_user)
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error issuing book: {str(e)}", exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Error issuing book: {str(e)}"
        )